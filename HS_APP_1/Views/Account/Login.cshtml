@*------------------------Login From---------------------------*@
<h2>Login</h2>
<form method="post">
	<div>
		<label>Username: </label><br />
		<input type="text" name="Username"/> @*Must match with property name*@
	</div>
	<div>
		<label>Password: </label><br />
		<input type="text" name="Password"/>
	</div>
	<button type="submit">Login</button>
</form>
@if(ViewBag.Error != null){
	<p>@ViewBag.Error</p>
}